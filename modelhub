#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import platform
import shutil
import subprocess
import sys
import signal
import tempfile
import time
from pathlib import Path
from typing import Iterable
import urllib.request


ROOT = Path(__file__).resolve().parent
MANIFEST = ROOT / "models.json"
CONTINUE_CONFIG = Path.home() / ".continue" / "config.yaml"
LOCAL_BIN = Path.home() / ".local" / "bin"
KNOWN_COMMANDS = {"install", "list", "serve", "up", "continue", "help", "-h", "--help"}
MODELHUB_PYTHON = sys.executable


def load_manifest() -> dict:
    with MANIFEST.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def models_by_id() -> dict[str, dict]:
    data = load_manifest()
    return {model["id"]: model for model in data["models"]}


def profiles() -> dict[str, list[str]]:
    return load_manifest().get("profiles", {})


def get_model(model_id: str) -> dict:
    models = models_by_id()
    if model_id not in models:
        raise SystemExit(f"Unknown model '{model_id}'. Available: {', '.join(sorted(models))}")
    return models[model_id]


def ensure_llama_server() -> str:
    llama_server = shutil.which("llama-server")
    if not llama_server:
        raise SystemExit("llama-server is not installed. Run `modelhub setup` first.")
    return llama_server


def is_windows() -> bool:
    return platform.system().lower().startswith("win")


def launcher_path(name: str) -> Path:
    if is_windows():
        return LOCAL_BIN / f"{name}.cmd"
    return LOCAL_BIN / name


def remove_launcher_variants(name: str) -> None:
    for candidate in {LOCAL_BIN / name, LOCAL_BIN / f"{name}.cmd", LOCAL_BIN / f"{name}.ps1"}:
        if candidate.exists() or candidate.is_symlink():
            candidate.unlink()


def write_windows_launcher(target: Path, script_path: Path) -> None:
    content = "\n".join(
        [
            "@echo off",
            "setlocal",
            f'"{MODELHUB_PYTHON}" "{script_path}" %*',
            "exit /b %errorlevel%",
            "",
        ]
    )
    target.write_text(content, encoding="utf-8", newline="\r\n")


def install_links() -> None:
    LOCAL_BIN.mkdir(parents=True, exist_ok=True)
    legacy_names = ["qwen-local"]
    for name in legacy_names:
        remove_launcher_variants(name)
    link_names = ["modelhub", *models_by_id().keys()]
    seen: set[str] = set()
    for name in link_names:
        if name in seen:
            continue
        seen.add(name)
        remove_launcher_variants(name)
        target = launcher_path(name)
        if is_windows():
            write_windows_launcher(target, ROOT / "modelhub")
        else:
            target.symlink_to(ROOT / "modelhub")
    print(f"Installed modelhub and model shortcuts in {LOCAL_BIN}")
    if f":{LOCAL_BIN}:" not in f":{os.environ.get('PATH', '')}:":
        print(f"Add {LOCAL_BIN} to PATH if needed.")


def setup_dependencies() -> None:
    if not shutil.which("llama-server"):
        system = platform.system().lower()
        if system == "darwin" or system == "linux":
            if shutil.which("brew"):
                subprocess.check_call(
                    [
                        "bash",
                        "-lc",
                        "HOMEBREW_NO_INSTALL_CLEANUP=1 HOMEBREW_NO_ENV_HINTS=1 brew install llama.cpp",
                    ]
                )
            elif shutil.which("nix"):
                subprocess.check_call(["nix", "profile", "install", "nixpkgs#llama-cpp"])
            else:
                raise SystemExit(
                    "Install llama.cpp with Homebrew or Nix, then rerun `modelhub setup`."
                )
        elif system.startswith("win"):
            if shutil.which("winget"):
                subprocess.check_call(["winget", "install", "llama.cpp"])
            else:
                raise SystemExit(
                    "Install llama.cpp with winget, then rerun `modelhub setup`."
                )
        else:
            raise SystemExit(f"Unsupported platform: {platform.system()}")
    else:
        print("llama-server already installed")


def infer_invocation_model(argv0: str) -> str | None:
    name = Path(argv0).stem
    return name if name in models_by_id() else None


def serve_model(model_id: str, extra_args: list[str]) -> None:
    model = get_model(model_id)
    llama_server = ensure_llama_server()
    host = os.environ.get("MODELHUB_HOST", load_manifest().get("default_host", "127.0.0.1"))
    port = os.environ.get("MODELHUB_PORT", str(model["port"]))
    cmd = [llama_server, "-hf", model["hf_repo"], "--host", host, "--port", port]
    cmd.extend(model.get("server_args", []))
    cmd.extend(extra_args)
    print(f"Serving {model['label']} on http://{host}:{port}", file=sys.stderr)
    raise SystemExit(subprocess.call(cmd))


def port_url(model: dict) -> str:
    host = os.environ.get("MODELHUB_HOST", load_manifest().get("default_host", "127.0.0.1"))
    return f"http://{host}:{model['port']}"


def ping_model(model: dict, proc: subprocess.Popen[str], timeout_seconds: int = 600) -> None:
    models_url = f"{port_url(model)}/v1/models"
    deadline = time.time() + timeout_seconds
    while time.time() < deadline:
        if proc.poll() is not None:
            raise SystemExit(f"{model['id']} exited early. Check the log for details.")
        try:
            with urllib.request.urlopen(models_url, timeout=5) as response:
                payload = json.load(response)
            if payload.get("data"):
                return
        except Exception:
            pass
        time.sleep(1)
    raise SystemExit(f"Timed out waiting for {models_url}")


def resolve_selection(selection: str | None) -> list[str]:
    data = load_manifest()
    model_ids = list(models_by_id().keys())
    selected = selection or "all"
    if selected in profiles():
        return profiles()[selected]
    if selected == "all":
        return model_ids
    if selected in model_ids:
        return [selected]
    raise SystemExit(
        f"Unknown profile or model '{selected}'. Available profiles: {', '.join(sorted(profiles()))}"
    )


def start_many(model_ids: Iterable[str], wait: bool = True) -> int:
    data = models_by_id()
    processes: list[tuple[str, subprocess.Popen[str], Path]] = []
    log_handles: list[object] = []
    log_dir = Path(tempfile.gettempdir()) / "local-model-hub"
    log_dir.mkdir(parents=True, exist_ok=True)

    def cleanup(*_args: object) -> None:
        for _model_id, proc, _log_file in processes:
            if proc.poll() is None:
                proc.terminate()
        for _model_id, proc, _log_file in processes:
            try:
                proc.wait(timeout=10)
            except Exception:
                if proc.poll() is None:
                    proc.kill()

    signal.signal(signal.SIGINT, cleanup)
    signal.signal(signal.SIGTERM, cleanup)

    try:
        for model_id in model_ids:
            model = data[model_id]
            log_file = log_dir / f"{model_id}.log"
            cmd = [
                ensure_llama_server(),
                "-hf",
                model["hf_repo"],
                "--host",
                os.environ.get("MODELHUB_HOST", load_manifest().get("default_host", "127.0.0.1")),
                "--port",
                str(model["port"]),
            ]
            cmd.extend(model.get("server_args", []))
            handle = log_file.open("a", encoding="utf-8")
            log_handles.append(handle)
            proc = subprocess.Popen(cmd, stdout=handle, stderr=handle, text=True)
            processes.append((model_id, proc, log_file))
            print(f"Starting {model['label']} on {port_url(model)} (log: {log_file})")

        for model_id, proc, log_file in processes:
            ping_model(data[model_id], proc)
            print(f"Ready: {model_id}")

        if not wait:
            return 0

        print("All selected servers are running. Press Ctrl-C to stop them.")
        while True:
            if any(proc.poll() is not None for _model_id, proc, _log_file in processes):
                break
            time.sleep(1)
    except KeyboardInterrupt:
        pass
    finally:
        cleanup()
        for handle in log_handles:
            try:
                handle.close()
            except Exception:
                pass
    return 0


def continue_model_entry(model: dict) -> str:
    lines = [
        "  - name: " + model["label"],
        "    provider: " + model.get("provider", "openai"),
        "    model: " + model["hf_repo"],
        f"    apiBase: http://{os.environ.get('MODELHUB_HOST', load_manifest().get('default_host', '127.0.0.1'))}:{model['port']}/v1",
        "    apiKey: none",
        "    roles:",
    ]
    lines.extend([f"      - {role}" for role in model.get("roles", ["chat", "edit", "apply"])])
    if model.get("capabilities"):
        lines.append("    capabilities:")
        lines.extend([f"      - {cap}" for cap in model["capabilities"]])
    if model.get("system_message"):
        lines.append("    systemMessage: |")
        lines.extend([f"      {line}" for line in model["system_message"].splitlines()])
    return "\n".join(lines)


def write_continue_config(path: Path) -> None:
    data = load_manifest()
    path.parent.mkdir(parents=True, exist_ok=True)
    body = [
        "name: " + data["name"],
        "version: 0.0.1",
        "schema: v1",
        "",
        "models:",
    ]
    for model in data["models"]:
        body.append(continue_model_entry(model))
    path.write_text("\n".join(body) + "\n", encoding="utf-8")


def print_models() -> None:
    data = load_manifest()
    for model in data["models"]:
        print(f"{model['id']:8} {model['label']:24} {model['hf_repo']}:{model['port']}")


def print_profiles() -> None:
    data = profiles()
    for name, model_ids in sorted(data.items()):
        print(f"{name:8} {', '.join(model_ids)}")


def command_continue(args: argparse.Namespace) -> None:
    if args.subcommand == "sync":
        target = Path(args.path) if args.path else CONTINUE_CONFIG
        write_continue_config(target)
        print(f"Wrote Continue config to {target}")
    elif args.subcommand == "print":
        data = load_manifest()
        print("name: " + data["name"])
        print("version: 0.0.1")
        print("schema: v1")
        print()
        print("models:")
        for model in data["models"]:
            print(continue_model_entry(model))
    else:
        raise SystemExit("Usage: modelhub continue [sync|print]")


def main(argv: list[str]) -> None:
    parser = argparse.ArgumentParser(prog=Path(argv[0]).name, add_help=True)
    sub = parser.add_subparsers(dest="cmd")

    sub.add_parser("install")
    sub.add_parser("setup")
    sub.add_parser("list")
    sub.add_parser("profiles")

    serve_parser = sub.add_parser("serve")
    serve_parser.add_argument("model", nargs="?")
    serve_parser.add_argument("extra", nargs=argparse.REMAINDER)

    up_parser = sub.add_parser("up")
    up_parser.add_argument("selection", nargs="?")

    cont = sub.add_parser("continue")
    cont_sub = cont.add_subparsers(dest="subcommand")
    sync = cont_sub.add_parser("sync")
    sync.add_argument("path", nargs="?")
    cont_sub.add_parser("print")

    parser.add_argument("rest", nargs=argparse.REMAINDER)

    argv0_model = infer_invocation_model(argv[0])

    if argv0_model and (len(argv) == 1 or argv[1] == "serve"):
        extra = argv[2:] if len(argv) > 1 and argv[1] == "serve" else argv[1:]
        serve_model(argv0_model, extra)

    if argv0_model and len(argv) == 2 and argv[1] not in KNOWN_COMMANDS:
        serve_model(argv0_model, argv[1:])

    args = parser.parse_args(argv[1:])

    if args.cmd == "install":
        install_links()
    elif args.cmd == "setup":
        setup_dependencies()
    elif args.cmd == "list":
        print_models()
    elif args.cmd == "profiles":
        print_profiles()
    elif args.cmd == "serve":
        model_id = args.model or argv0_model
        if not model_id:
            raise SystemExit("Usage: modelhub serve <model>")
        serve_model(model_id, args.extra)
    elif args.cmd == "up":
        selection = args.selection or "all"
        model_ids = resolve_selection(selection)
        raise SystemExit(start_many(model_ids))
    elif args.cmd == "continue":
        command_continue(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main(sys.argv)
